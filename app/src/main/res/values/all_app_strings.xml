    <string name="label_last_updated">Last updated: </string>
    <string name="text_last_updated_date">April 28, 2026</string>
    <string name="text_terms_intro">Welcome to Tube AIO - NextGen. By using our app, you agree to comply with and be bound by the following terms.</string>
    <string name="title_acceptance_terms">Acceptance of Terms</string>
    <string name="desc_acceptance_terms">By accessing or using Tube AIO - NextGen, you agree to be bound by these Terms &amp; Conditions and our Privacy Policy.</string>
    <string name="extra_acceptance_terms">By using this application, you acknowledge that you have read, understood, and agreed to be bound by these terms. This agreement applies to all visitors, users, and others who access the service. If you disagree with any part of the terms, then you may not access the service.</string>
    <string name="title_use_of_app">Use of the App</string>
    <string name="desc_use_of_app">You agree to use the app in accordance with these terms and only for lawful purposes. You shall not misuse the app in any way.</string>
    <string name="extra_use_of_app">You are responsible for any activity that occurs through your use of the app. You must not use the service for any illegal or unauthorized purpose. International users agree to comply with all local laws regarding online conduct and acceptable content.</string>
    <string name="title_intellectual_property">Intellectual Property</string>
    <string name="desc_intellectual_property">All content, features, and materials in the app are owned by Tube AIO - NextGen and protected by copyright laws.</string>
    <string name="extra_intellectual_property">The service and its original content (excluding content provided by users), features, and functionality are and will remain the exclusive property of TubeAIO and its licensors. Our trademarks and trade dress may not be used in connection with any product or service without prior written consent.</string>
    <string name="title_prohibited_activities">Prohibited Activities</string>
    <string name="desc_prohibited_activities">You agree not to copy, modify, distribute, or reverse engineer any part of the app or its services.</string>
    <string name="extra_prohibited_activities">You specifically agree not to: (1) access the service using automated means (bots/scrapers); (2) attempt to interfere with the proper working of the service; (3) bypass measures used to prevent or restrict access; or (4) decompile, disassemble, or reverse engineer the software.</string>
    <string name="title_limitation_liability">Limitation of Liability</string>
    <string name="desc_limitation_liability">We are not responsible for any direct or indirect damages resulting from the use or inability to use the app.</string>
    <string name="extra_limitation_liability">In no event shall TubeAIO, nor its directors, employees, or partners, be liable for any indirect, incidental, special, consequential, or punitive damages, including without limitation, loss of profits, data, use, goodwill, or other intangible losses, resulting from your access to or use of the service.</string>
    <string name="title_changes_to_terms">Changes to Terms</string>
    <string name="desc_changes_to_terms">We may change these rules sometimes. If you keep using the app, it means you agree to the new rules.</string>
    <string name="extra_changes_to_terms">We reserve the right, at our sole discretion, to modify or replace these terms at any time. If a revision is material, we will try to provide at least 30 days\' notice prior to any new terms taking effect. What constitutes a material change will be determined at our sole discretion.</string>
