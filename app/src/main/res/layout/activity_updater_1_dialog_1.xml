<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
  xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  xmlns:tools="http://schemas.android.com/tools"
  android:layout_width="match_parent"
  android:layout_height="wrap_content"
  android:orientation="vertical">

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_gravity="center_horizontal"
    android:background="@drawable/ic_rd_background_color"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:layout_marginLeft="10dp"
    android:layout_marginRight="10dp"
    android:paddingTop="5dp"
    android:paddingBottom="5dp">

    <com.google.android.material.textview.MaterialTextView
      android:id="@+id/tvPercentage"
      android:layout_width="50dp"
      android:layout_height="wrap_content"
      android:ellipsize="end"
      android:fontFamily="@font/font_family_medium"
      android:gravity="left|center_vertical"
      android:maxLines="1"
      android:paddingLeft="10dp"
      android:paddingRight="10dp"
      android:singleLine="true"
      android:textColor="@color/style_color_text_primary"
      android:textSize="@dimen/message_text_size"

      tools:ignore="SpUsage,TextSizeCheck"
      tools:text="100%" />

    <com.google.android.material.progressindicator.LinearProgressIndicator
      android:id="@+id/pbDownload"
      android:layout_width="match_parent"
      android:layout_height="8dp"
      android:layout_gravity="center_vertical"
      android:max="100"
      android:paddingRight="15dp"
      app:indicatorColor="@color/style_color_primary"
      app:trackColor="@color/style_color_primary_light"
      app:trackCornerRadius="5dp"
      app:trackThickness="8dp"
      tools:progress="10" />
  </LinearLayout>

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="10dp"
    android:layout_marginBottom="12dp"
    android:baselineAligned="false"
    android:orientation="horizontal">

    <LinearLayout
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:layout_weight="1"
      android:gravity="center"
      android:orientation="vertical">

      <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/ivSpeed"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:contentDescription="@string/label_download_speed"
        android:src="@drawable/ic_speed_meter"
        app:tint="@color/style_color_icon" />

      <com.google.android.material.textview.MaterialTextView
        android:id="@+id/tvSpeedValue"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="5dp"
        android:fontFamily="@font/font_family_bold"
        android:textColor="@color/style_color_text_primary"
        android:textSize="@dimen/small_text_size"

        tools:ignore="SpUsage,TextSizeCheck"
        tools:text="@string/label_sample_0_mb_s" />

      <com.google.android.material.textview.MaterialTextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/label_download_speed"
        android:textColor="@color/style_color_text_secondary"
        android:textSize="@dimen/smaller_text_size"
        tools:ignore="SpUsage,TextSizeCheck,TextContrastCheck" />
    </LinearLayout>

    <View
      android:layout_width="1dp"
      android:layout_height="match_parent"
      android:alpha="0.1"
      android:background="@color/color_text_hint" />

    <LinearLayout
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:layout_weight="1"
      android:gravity="center"
      android:orientation="vertical">

      <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/ivTime"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:contentDescription="@string/label_download_speed"
        android:src="@drawable/ic_stopwatch_timer"
        app:tint="@color/style_color_icon" />

      <com.google.android.material.textview.MaterialTextView
        android:id="@+id/tvTimeValue"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="5dp"
        android:fontFamily="@font/font_family_bold"
        android:textColor="@color/style_color_text_primary"
        android:textSize="@dimen/small_text_size"

        tools:ignore="SpUsage,TextSizeCheck"
        tools:text="@string/label_sample_0_mb_s" />

      <com.google.android.material.textview.MaterialTextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/label_time_left"
        android:textColor="@color/style_color_text_secondary"
        android:textSize="@dimen/smaller_text_size"
        tools:ignore="SpUsage,TextSizeCheck,TextContrastCheck" />
    </LinearLayout>

    <View
      android:layout_width="1dp"
      android:layout_height="match_parent"
      android:alpha="0.1"
      android:background="@color/color_text_hint" />

    <LinearLayout
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:layout_weight="1"
      android:gravity="center"
      android:orientation="vertical">

      <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/ivSize"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:contentDescription="@string/label_download_speed"
        android:src="@drawable/ic_apk_file_install"
        app:tint="@color/style_color_icon" />

      <com.google.android.material.textview.MaterialTextView
        android:id="@+id/tvTotalSize"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="5dp"
        android:fontFamily="@font/font_family_bold"
        android:textColor="@color/style_color_text_primary"
        android:textSize="@dimen/small_text_size"

        tools:ignore="SpUsage,TextSizeCheck"
        tools:text="@string/label_sample_0_mb_s" />

      <com.google.android.material.textview.MaterialTextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/label_total_size"
        android:textColor="@color/style_color_text_secondary"
        android:textSize="@dimen/smaller_text_size"
        tools:ignore="SpUsage,TextSizeCheck,TextContrastCheck" />
    </LinearLayout>
  </LinearLayout>

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/ic_rd_bg_secondary_color"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="10dp">

    <com.google.android.material.imageview.ShapeableImageView
      android:id="@+id/ivShield"
      android:layout_width="50dp"
      android:layout_height="50dp"
      android:background="@drawable/bg_color_circle"
      android:backgroundTint="@color/style_color_error"
      android:importantForAccessibility="no"
      android:padding="5dp"
      android:scaleType="centerInside"
      android:src="@drawable/ic_shield_lock_fill"
      android:tint="@color/color_surface"
      app:shapeAppearance="@style/circular_image_view"
      tools:ignore="UseAppTint" />

    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginLeft="10dp"
      android:orientation="vertical">

      <com.google.android.material.textview.MaterialTextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"

        android:fontFamily="@font/font_family_semibold"

        android:text="@string/label_dont_close_app"
        android:textColor="@color/style_color_error_text"
        android:textSize="@dimen/normal_text_size"

        tools:ignore="SpUsage,TextSizeCheck" />

      <com.google.android.material.textview.MaterialTextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"

        android:fontFamily="@font/font_family_regular"
        android:maxLines="3"
        android:singleLine="false"

        android:text="@string/subtext_stay_connected"
        android:textColor="@color/style_color_text_secondary"
        android:textSize="@dimen/message_text_size"

        tools:ignore="SpUsage,TextSizeCheck,TextContrastCheck" />

    </LinearLayout>
  </LinearLayout>
</LinearLayout>