<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
  xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  xmlns:tools="http://schemas.android.com/tools"
  android:layout_width="match_parent"
  android:layout_height="wrap_content"
  android:layout_margin="10dp"
  app:cardBackgroundColor="@color/style_color_card"
  app:cardCornerRadius="5dp"
  app:cardElevation="0dp"
  app:strokeColor="@color/style_color_card_stroke"
  app:strokeWidth="1dp">

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <RelativeLayout
      android:id="@+id/containerTitle"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:background="@color/style_color_background_secondary"
      android:orientation="horizontal"
      android:visibility="visible"

      tools:visibility="visible">

      <com.google.android.material.textview.MaterialTextView
        android:id="@+id/tvDialogTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerVertical="true"
        android:layout_toLeftOf="@id/btnCloseDialog"
        android:fontFamily="@font/font_family_medium"
        android:gravity="center_vertical|center_horizontal"
        android:padding="10dp"
        android:textColor="@color/style_color_text_primary"
        android:textSize="@dimen/sub_heading_text_size"
        tools:ignore="SpUsage,TextSizeCheck"
        tools:text="Dialog Title Goes Here" />

      <ImageView
        android:id="@+id/btnCloseDialog"
        android:layout_width="@dimen/_40"
        android:layout_height="@dimen/_40"
        android:layout_alignParentRight="true"
        android:layout_centerVertical="true"
        android:layout_gravity="right|top"
        android:layout_marginRight="5dp"
        android:adjustViewBounds="true"
        android:background="@drawable/bg_button_negative"
        android:clickable="true"
        android:importantForAccessibility="no"
        android:padding="8dp"
        android:src="@drawable/ic_close_cross"
        android:tint="@color/style_color_button_primary"

        tools:ignore="ImageContrastCheck,TouchTargetSizeCheck,UseAppTint"
        tools:visibility="visible" />
    </RelativeLayout>

    <View
      android:layout_width="match_parent"
      android:layout_height="1dp"
      android:background="@color/style_color_divider" />

    <LinearLayout
      android:id="@+id/mainContent"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginLeft="10dp"
      android:layout_marginTop="10dp"
      android:layout_marginRight="10dp"
      android:layout_marginBottom="6dp"
      android:orientation="vertical" />

    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginLeft="7dp"
      android:layout_marginRight="7dp"
      android:layout_marginBottom="5dp"
      android:orientation="vertical">

      <com.google.android.material.button.MaterialButton
        android:id="@+id/btnDialogRight"
        style="@style/Widget.Material3.Button.IconButton.Filled"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:ellipsize="end"
        android:fontFamily="@font/font_family_medium"
        android:maxLines="1"
        android:singleLine="true"
        android:textAllCaps="false"
        android:textSize="@dimen/normal_text_size"
        app:backgroundTint="@color/style_color_button_primary"
        app:cornerRadius="5dp"
        app:icon="@drawable/ic_okay_check"
        app:iconGravity="textStart"
        app:iconPadding="10dp"
        app:iconSize="24dp"

        tools:ignore="SpUsage,VisualLintButtonSize,TextSizeCheck"
        tools:text="@string/label_okay" />

      <com.google.android.material.button.MaterialButton
        android:id="@+id/btnDialogLeft"
        style="@style/Widget.Material3.Button.IconButton.Outlined"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:ellipsize="end"
        android:fontFamily="@font/font_family_medium"
        android:maxLines="1"
        android:singleLine="true"
        android:textColor="@color/style_color_button_outline"
        android:textSize="@dimen/normal_text_size"
        android:visibility="gone"
        app:cornerRadius="5dp"
        app:icon="@drawable/ic_close_cross"
        app:iconGravity="textStart"
        app:iconPadding="10dp"
        app:iconSize="24dp"
        app:iconTint="@color/style_color_button_primary"
        app:strokeColor="@color/style_color_button_outline"
        app:strokeWidth="1dp"
        tools:ignore="SpUsage,VisualLintButtonSize,TextSizeCheck"

        tools:text="@string/label_cancel"
        tools:visibility="visible" />
    </LinearLayout>
  </LinearLayout>
</com.google.android.material.card.MaterialCardView>