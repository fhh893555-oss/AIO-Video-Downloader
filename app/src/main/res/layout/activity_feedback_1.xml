<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
  xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:tools="http://schemas.android.com/tools"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:background="@drawable/img_bg_activity_v2"
  android:fillViewport="true">

  <FrameLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    tools:ignore="UselessParent">

    <ImageView
      android:layout_width="@dimen/_190"
      android:layout_height="wrap_content"
      android:layout_gravity="right"
      android:layout_marginTop="@dimen/_20"
      android:adjustViewBounds="true"
      android:src="@drawable/img_feedback_act_corner"
      tools:ignore="ContentDescription,ImageContrastCheck" />

    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:orientation="vertical">

      <ImageView
        android:id="@+id/btnBack"
        android:layout_width="@dimen/_50"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/_10"
        android:adjustViewBounds="true"
        android:background="@drawable/bg_button_negative"
        android:clickable="true"
        android:focusable="true"
        android:src="@drawable/img_arrow_back"
        tools:ignore="ContentDescription,SpeakableTextPresentCheck" />

      <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:orientation="vertical">

          <include
            android:id="@+id/top_1"
            layout="@layout/activity_feedback_1_top_1" />

          <include
            android:id="@+id/top_2"
            layout="@layout/activity_feedback_1_top_2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

          <include
            android:id="@+id/top_3"
            layout="@layout/activity_feedback_1_top_3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="-10dp" />
        </LinearLayout>
      </ScrollView>
    </LinearLayout>
  </FrameLayout>
</LinearLayout>
