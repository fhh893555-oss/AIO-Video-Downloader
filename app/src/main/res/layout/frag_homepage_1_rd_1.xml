<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
  xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  xmlns:tools="http://schemas.android.com/tools"
  android:layout_width="match_parent"
  android:layout_height="wrap_content"
  android:fitsSystemWindows="true"
  android:orientation="vertical"
  tools:ignore="ContentDescription,HardcodedText,ImageContrastCheck,
    RtlHardcoded,SmallSp,SpeakableTextPresentCheck,TouchTargetSizeCheck,UseAppTint,
    UseCompatTextViewDrawableXml,UselessLeaf">

  <RelativeLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <TextView
      style="@style/style_textviews"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_centerVertical="true"
      android:layout_toLeftOf="@+id/homepage_recent_downloads_view_all_button"
      android:drawableLeft="@drawable/ic_recent_save_small"
      android:fontFamily="@font/font_family_semibold"
      android:text="@string/title_recently_downloaded"
      tools:ignore="VisualLintSystemUi" />

    <TextView
      android:id="@+id/homepage_recent_downloads_view_all_button"
      style="@style/style_textviews"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_alignParentRight="true"
      android:layout_centerVertical="true"
      android:background="@drawable/ic_button_surface_selector"
      android:clickable="true"
      android:drawableRight="@drawable/ic_key_arrow_right"
      android:drawableTint="@color/color_text_secondary"
      android:fontFamily="@font/font_family_medium"
      android:paddingLeft="@dimen/_10"
      android:text="@string/title_view_all"
      android:textColor="@color/color_text_secondary"
      android:textSize="@dimen/small_text_size"
      tools:ignore="TouchTargetSizeCheck,VisualLintSystemUi" />
  </RelativeLayout>

  <LinearLayout
    android:id="@+id/homepage_recent_downloads_empty_container"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="@dimen/_5"
    android:orientation="vertical"
    android:visibility="gone">

    <com.airbnb.lottie.LottieAnimationView
      android:id="@+id/homepage_recent_downloads_empty_image"
      android:layout_width="@dimen/_150"
      android:layout_height="wrap_content"
      android:layout_gravity="center"
      android:layout_marginTop="@dimen/_5"
      android:adjustViewBounds="true"
      android:hardwareAccelerated="true"
      android:importantForAccessibility="no"
      android:layerType="hardware"
      android:minHeight="@dimen/_50"
      app:lottie_autoPlay="true"
      app:lottie_enableMergePathsForKitKatAndAbove="true"
      app:lottie_loop="true"
      tools:ignore="ImageContrastCheck" />

    <TextView
      style="@style/style_textviews"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_gravity="center_horizontal"
      android:fontFamily="@font/font_family_italic"
      android:gravity="center"
      android:maxLines="2"
      android:singleLine="false"
      android:text="@string/title_you_dont_have_any_downloads"
      android:textSize="@dimen/small_text_size" />

    <TextView
      android:id="@+id/homepage_recent_downloads_how_to_download"
      style="@style/style_textviews"
      android:layout_width="wrap_content"
      android:layout_height="@dimen/_30"
      android:layout_gravity="center_horizontal"
      android:layout_marginTop="@dimen/_0"
      android:background="@drawable/ic_button_secondary_selector"
      android:clickable="true"
      android:drawableLeft="@drawable/ic_question_info"
      android:drawablePadding="@dimen/_5"
      android:drawableTint="@color/color_on_secondary"
      android:fontFamily="@font/font_family_medium"
      android:paddingLeft="@dimen/_5"
      android:paddingRight="@dimen/_8"
      android:text="@string/title_how_to_download_something"
      android:textColor="@color/color_on_secondary"
      tools:ignore="TextContrastCheck,TouchTargetSizeCheck" />
  </LinearLayout>

  <androidx.recyclerview.widget.RecyclerView
    android:id="@+id/homepage_recent_downloads_recycle_view"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_gravity="center_horizontal"
    android:layout_marginBottom="@dimen/_5"
    app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
    app:spanCount="2" />

</LinearLayout>
