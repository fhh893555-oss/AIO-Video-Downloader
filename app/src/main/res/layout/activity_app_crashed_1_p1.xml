<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="@color/style_color_surface"
    app:cardCornerRadius="5dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/style_color_border"
    app:strokeWidth="1dp"
    tools:layout_marginLeft="20dp"
    tools:layout_marginRight="20dp"
    tools:layout_marginTop="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingLeft="10dp"
            android:paddingTop="5dp"
            android:paddingRight="10dp"
            android:paddingBottom="5dp">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/ivIdCard"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_centerVertical="true"
                android:importantForAccessibility="no"
                android:src="@drawable/ic_id_card"
                android:tint="@color/style_color_text_secondary"
                tools:ignore="UseAppTint" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_marginLeft="20dp"
                android:layout_marginRight="40dp"
                android:layout_toLeftOf="@+id/btnCopyUserDeviceId"
                android:layout_toRightOf="@id/ivIdCard"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvTitleUserDeviceId"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/font_family_medium"
                    android:text="@string/label_device_id"
                    android:textColor="@color/style_color_text_secondary"
                    android:textSize="@dimen/normal_text_size"
                    tools:ignore="SpUsage,TextSizeCheck" />

                <TextView
                    android:id="@+id/tvUserDeviceId"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:ellipsize="end"
                    android:fontFamily="@font/font_family_regular"
                    android:singleLine="true"
                    android:textColor="@color/color_text_hint"
                    android:textSize="@dimen/message_text_size"
                    tools:ignore="SpUsage,TextSizeCheck,TextContrastCheck"
                    tools:text="8c5f34f7eacb034748f906a397dd58fa331b3bf0" />
            </LinearLayout>

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/btnCopyUserDeviceId"
                android:layout_width="38dp"
                android:layout_height="30dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:adjustViewBounds="true"
                android:background="@drawable/bg_button_negative"
                android:clickable="true"
                android:hapticFeedbackEnabled="true"
                android:padding="6dp"
                android:src="@drawable/ic_content_copy"
                android:tint="@color/style_color_button_outline"
                tools:ignore="SpeakableTextPresentCheck,TouchTargetSizeCheck" />
        </RelativeLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginLeft="10dp"
            android:layout_marginRight="10dp"
            android:background="@color/style_color_divider" />

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingLeft="10dp"
            android:paddingTop="5dp"
            android:paddingRight="10dp"
            android:paddingBottom="5dp">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/ivApplicationVersion"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_centerVertical="true"
                android:importantForAccessibility="no"
                android:src="@drawable/ic_apk_document"
                android:tint="@color/style_color_text_secondary"
                tools:ignore="UseAppTint" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_marginLeft="20dp"
                android:layout_marginRight="20dp"
                android:layout_toRightOf="@id/ivApplicationVersion"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvTitleApplicationVersion"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/font_family_medium"
                    android:text="@string/label_app_version"
                    android:textColor="@color/style_color_text_secondary"
                    android:textSize="@dimen/normal_text_size"
                    tools:ignore="SpUsage,TextSizeCheck" />

                <TextView
                    android:id="@+id/tvApplicationVersion"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:fontFamily="@font/font_family_regular"
                    android:textColor="@color/color_text_hint"
                    android:textSize="@dimen/message_text_size"
                    tools:ignore="SpUsage,TextSizeCheck,TextContrastCheck"
                    tools:text="v2026.10.08 | Build No. 28" />
            </LinearLayout>
        </RelativeLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginLeft="10dp"
            android:layout_marginRight="10dp"
            android:background="@color/style_color_divider" />

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingLeft="10dp"
            android:paddingTop="5dp"
            android:paddingRight="10dp"
            android:paddingBottom="5dp">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/ivAndroidVersion"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_centerVertical="true"
                android:importantForAccessibility="no"
                android:src="@drawable/ic_package"
                android:tint="@color/style_color_text_secondary"
                tools:ignore="UseAppTint" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_marginLeft="20dp"
                android:layout_marginRight="20dp"
                android:layout_toRightOf="@id/ivAndroidVersion"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvTitleAndroidVersion"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/font_family_medium"
                    android:text="@string/label_android_version"
                    android:textColor="@color/style_color_text_secondary"
                    android:textSize="@dimen/normal_text_size"
                    tools:ignore="SpUsage,TextSizeCheck" />

                <TextView
                    android:id="@+id/tvAndroidVersion"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:fontFamily="@font/font_family_regular"
                    android:textColor="@color/color_text_hint"
                    android:textSize="@dimen/message_text_size"
                    tools:ignore="SpUsage,TextSizeCheck,TextContrastCheck"
                    tools:text="Android 15 (SDK 36)" />
            </LinearLayout>
        </RelativeLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginLeft="10dp"
            android:layout_marginRight="10dp"
            android:background="@color/style_color_divider" />

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingLeft="10dp"
            android:paddingTop="5dp"
            android:paddingRight="10dp"
            android:paddingBottom="5dp">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/ivCrashTime"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_centerVertical="true"
                android:importantForAccessibility="no"
                android:src="@drawable/ic_calender"
                android:tint="@color/style_color_text_secondary"
                tools:ignore="UseAppTint" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_marginLeft="20dp"
                android:layout_marginRight="20dp"
                android:layout_toRightOf="@id/ivCrashTime"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvTitleCrashTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/font_family_medium"
                    android:text="@string/label_system_crashed_at"
                    android:textColor="@color/style_color_text_secondary"
                    android:textSize="@dimen/normal_text_size"
                    tools:ignore="SpUsage,TextSizeCheck" />

                <TextView
                    android:id="@+id/tvCrashTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:fontFamily="@font/font_family_regular"
                    android:textColor="@color/color_text_hint"
                    android:textSize="@dimen/message_text_size"
                    tools:ignore="SpUsage,TextSizeCheck,TextContrastCheck"
                    tools:text="11th Jun 2026 * 13:16" />
            </LinearLayout>
        </RelativeLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginLeft="10dp"
            android:layout_marginRight="10dp"
            android:background="@color/style_color_divider" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
