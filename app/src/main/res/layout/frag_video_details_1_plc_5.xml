<?xml version="1.0" encoding="utf-8"?>
<com.github.dangiashish.StyledCardView
  xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  xmlns:tools="http://schemas.android.com/tools"
  android:layout_width="match_parent"
  android:layout_height="wrap_content"
  app:background_ColorType="gradient_linear"
  app:background_Gradient_Angle="45"
  app:background_Gradient_Color0="@color/color_card"
  app:background_Gradient_Color1="@color/color_surface"
  app:background_Type="fill_stroke"
  app:cornerRadius="@dimen/default_radius"
  app:shadow0_Outer_Alpha=".1"
  app:shadow0_Outer_Angle="-45"
  app:shadow0_Outer_Blur="@dimen/_5"
  app:shadow0_Outer_Color="@color/color_primary_variant"
  app:shadow0_Outer_Distance="@dimen/_5"
  app:shadow1_Outer_Alpha="0.1"
  app:shadow1_Outer_Angle="360"
  app:shadow1_Outer_Blur="@dimen/_5"
  app:shadow1_Outer_Color="@color/color_secondary"
  app:shadow1_Outer_Distance="@dimen/_2"
  app:shadow_Outer_Area="@dimen/_10"
  app:stroke_Alpha=".3"
  app:stroke_ColorType="gradient_sweep"
  app:stroke_Gradient_Angle="-45"
  app:stroke_Gradient_Color0="@color/color_primary"
  app:stroke_Gradient_Color1="@color/color_primary_variant"
  app:stroke_Width="1dp">

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    tools:ignore="UselessParent">

    <RelativeLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginLeft="@dimen/_10"
      android:layout_marginTop="@dimen/_10"
      android:layout_marginRight="@dimen/_10"
      android:layout_marginBottom="@dimen/_0"
      android:orientation="horizontal">

      <TextView
        android:id="@+id/tvRelatedVideos"
        style="@style/style_textviews"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentLeft="true"
        android:layout_centerVertical="true"
        android:layout_gravity="center_vertical"
        android:layout_margin="@dimen/_0"
        android:layout_toLeftOf="@+id/btnPlayNext"
        android:fontFamily="@font/font_family_semibold"
        android:gravity="center_vertical"
        android:text="@string/label_related_videos"
        android:textColor="@color/color_text_primary"
        android:textSize="@dimen/sub_heading_text_size_v2"
        tools:ignore="SpUsage,TextSizeCheck,VisualLintSystemUi" />

      <TextView
        android:id="@+id/btnPlayNext"
        style="@style/style_textviews"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/_28"
        android:layout_alignParentRight="true"
        android:layout_centerVertical="true"
        android:layout_margin="@dimen/_0"
        android:background="@drawable/bg_button_negative"
        android:clickable="true"
        android:drawableRight="@drawable/ic_toggle_off"
        android:drawablePadding="@dimen/_5"
        android:drawableTint="@color/color_text_primary"
        android:fontFamily="@font/font_family_medium"
        android:gravity="center_vertical"
        android:paddingLeft="@dimen/_10"
        android:paddingTop="@dimen/_2"
        android:paddingRight="@dimen/_10"
        android:paddingBottom="@dimen/_2"
        android:text="@string/label_play_next_video"
        android:textSize="@dimen/message_text_size"
        tools:ignore="RelativeOverlap,SpUsage,UseCompatTextViewDrawableXml,
        TextSizeCheck,VisualLintSystemUi,TouchTargetSizeCheck" />
    </RelativeLayout>

    <FrameLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content">

      <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/relatedVideosList"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginLeft="@dimen/_5"
        android:layout_marginTop="@dimen/_0"
        android:layout_marginRight="@dimen/_5"
        android:layout_marginBottom="@dimen/_0"
        app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
        app:spanCount="2"
        tools:listitem="@layout/frag_video_details_1_plc_6" />

      <View
        android:layout_width="match_parent"
        android:layout_height="@dimen/_5"
        android:layout_gravity="top|center_horizontal"
        android:background="@drawable/bg_shadow_border_2" />

      <View
        android:layout_width="match_parent"
        android:layout_height="@dimen/_10"
        android:layout_gravity="bottom|center_horizontal"
        android:background="@drawable/bg_shadow_border" />
    </FrameLayout>

  </LinearLayout>
</com.github.dangiashish.StyledCardView>