<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
  xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:tools="http://schemas.android.com/tools"
  android:id="@+id/minPlayerContainer"
  android:layout_width="match_parent"
  android:layout_height="@dimen/_45"
  android:orientation="horizontal">

  <ImageView
    android:id="@+id/imgThumbnail"
    android:layout_width="@dimen/_40"
    android:layout_height="@dimen/_30"
    android:layout_alignParentLeft="true"
    android:layout_centerVertical="true"
    android:layout_marginLeft="@dimen/_5"
    android:layout_marginTop="@dimen/_5"
    android:layout_marginBottom="@dimen/_5"
    android:importantForAccessibility="no"
    android:scaleType="centerCrop"
    android:src="@drawable/bg_media_placeholder"
    tools:ignore="ImageContrastCheck" />

  <LinearLayout
    android:id="@+id/videoInfoContainer"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_centerVertical="true"
    android:layout_margin="@dimen/_5"
    android:layout_toLeftOf="@+id/controllerContainer"
    android:layout_toRightOf="@+id/imgThumbnail"
    android:background="@color/transparent"
    android:clickable="true"
    android:orientation="vertical"
    android:textStyle="italic"
    tools:ignore="TouchTargetSizeCheck">

    <TextView
      android:id="@+id/tvVideoTitle"
      style="@style/style_textviews"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_gravity="top"
      android:layout_margin="@dimen/_0"
      android:fontFamily="@font/font_family_semibold"
      android:text="@string/label_sample_video_title"
      android:textSize="@dimen/message_text_size"
      tools:ignore="SpUsage,TextSizeCheck,VisualLintSystemUi" />

    <TextView
      android:id="@+id/tvChannelName"
      style="@style/style_textviews"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_gravity="top"
      android:layout_marginLeft="@dimen/_0"
      android:layout_marginTop="@dimen/_2"
      android:layout_marginRight="@dimen/_5"
      android:layout_marginBottom="@dimen/_0"
      android:fontFamily="@font/font_family_regular"
      android:text="@string/label_sample_channel_name"
      android:textSize="@dimen/small_text_size"
      tools:ignore="SpUsage,TextSizeCheck,VisualLintSystemUi" />
  </LinearLayout>

  <LinearLayout
    android:id="@+id/controllerContainer"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_alignParentRight="true"
    android:layout_centerVertical="true"
    android:orientation="horizontal"
    android:paddingTop="@dimen/_5"
    android:paddingBottom="@dimen/_5">

    <ImageView
      android:id="@+id/btnOpenPlaylist"
      android:layout_width="@dimen/_30"
      android:layout_height="match_parent"
      android:layout_gravity="center_vertical"
      android:layout_marginRight="@dimen/_5"
      android:adjustViewBounds="true"
      android:background="@drawable/bg_button_negative"
      android:clickable="true"
      android:importantForAccessibility="no"
      android:padding="@dimen/_5"
      android:src="@drawable/ic_media_playlist"
      android:tint="@color/color_text_primary"
      tools:ignore="UseAppTint,TouchTargetSizeCheck" />

    <ImageView
      android:id="@+id/btnTogglePlayback"
      android:layout_width="@dimen/_30"
      android:layout_height="match_parent"
      android:layout_gravity="center_vertical"
      android:layout_marginRight="@dimen/_5"
      android:adjustViewBounds="true"
      android:background="@drawable/bg_button_negative"
      android:clickable="true"
      android:importantForAccessibility="no"
      android:padding="@dimen/_6"
      android:src="@drawable/ic_playback_pause"
      android:tint="@color/color_text_primary"
      tools:ignore="UseAppTint,TouchTargetSizeCheck" />

    <ImageView
      android:id="@+id/btnCancelPlayer"
      android:layout_width="@dimen/_30"
      android:layout_height="match_parent"
      android:layout_gravity="center_vertical"
      android:layout_marginRight="@dimen/_5"
      android:adjustViewBounds="true"
      android:background="@drawable/bg_button_negative"
      android:clickable="true"
      android:importantForAccessibility="no"
      android:padding="@dimen/_6"
      android:src="@drawable/ic_cancel_circle"
      android:tint="@color/color_text_primary"
      tools:ignore="UseAppTint,TouchTargetSizeCheck" />
  </LinearLayout>

</RelativeLayout>