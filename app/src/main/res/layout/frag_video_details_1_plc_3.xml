<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
  xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  xmlns:tools="http://schemas.android.com/tools"
  android:layout_width="match_parent"
  android:layout_height="wrap_content"
  android:layout_marginLeft="@dimen/_5"
  android:layout_marginTop="@dimen/_5"
  android:layout_marginRight="@dimen/_5"
  android:baselineAligned="false">

  <LinearLayout
    android:id="@+id/videoDetailsContainer"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_centerVertical="true"
    android:layout_marginRight="@dimen/_10"
    android:layout_toStartOf="@id/viewCountsLikeContainer"
    android:layout_toLeftOf="@id/viewCountsLikeContainer">

    <FrameLayout
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_gravity="center_vertical">

      <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/detail_sub_channel_thumbnail_view"
        android:layout_width="@dimen/_38"
        android:layout_height="@dimen/_38"
        android:adjustViewBounds="true"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_person_avatar"
        app:shapeAppearance="@style/CircularImageView" />
    </FrameLayout>

    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_gravity="center_vertical"
      android:layout_marginLeft="@dimen/_5"
      android:gravity="center_vertical"
      android:orientation="vertical">

      <TextView
        android:id="@+id/tvChannelName"
        style="@style/style_textviews"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/_0"
        android:fontFamily="@font/font_family_semibold"
        android:textColor="@color/color_text_primary"
        android:textSize="@dimen/sub_heading_text_size"
        tools:ignore="RtlHardcoded,SpUsage"
        tools:text="@string/label_channel_name" />

      <TextView
        android:id="@+id/tvChannelSubsCount"
        style="@style/style_textviews"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/_0"
        android:layout_marginTop="@dimen/_3"
        android:layout_marginRight="@dimen/_0"
        android:layout_marginBottom="@dimen/_0"
        android:fontFamily="@font/font_family_regular"
        android:textColor="@color/color_text_primary"
        android:textSize="@dimen/small_text_size"
        tools:ignore="RtlHardcoded,SpUsage"
        tools:text="@string/label_100k_subscribers" />
    </LinearLayout>
  </LinearLayout>

  <LinearLayout
    android:id="@+id/viewCountsLikeContainer"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_alignParentEnd="true"
    android:layout_alignParentRight="true"
    android:layout_centerVertical="true"
    android:orientation="vertical">

    <TextView
      android:id="@+id/tvVideoViewsCount"
      style="@style/style_textviews"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_margin="@dimen/_0"
      android:fontFamily="@font/font_family_medium"
      android:lines="1"
      android:textColor="@color/color_text_primary"
      android:textSize="@dimen/message_text_size"
      tools:ignore="RtlHardcoded"
      tools:text="2,816,821,505 views" />

    <LinearLayout
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_gravity="right"
      android:layout_marginTop="@dimen/_5"
      android:orientation="horizontal">

      <ImageView
        android:id="@+id/imgThumbUp"
        android:layout_width="@dimen/_12"
        android:layout_height="@dimen/_12"
        android:layout_gravity="center_vertical"
        android:layout_marginLeft="@dimen/_0"
        android:layout_marginRight="@dimen/_5"
        android:adjustViewBounds="true"
        android:src="@drawable/ic_thumb_up"
        android:tint="@color/color_text_primary"
        tools:ignore="RtlHardcoded,UseAppTint" />

      <TextView
        android:id="@+id/tvViewLikeCount"
        style="@style/style_textviews"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical"
        android:layout_margin="@dimen/_0"
        android:fontFamily="@font/font_family_medium"
        android:gravity="center_vertical"
        android:textColor="@color/color_text_primary"
        android:textSize="@dimen/small_text_size"
        tools:ignore="RtlHardcoded"
        tools:text="10K" />
    </LinearLayout>
  </LinearLayout>
</RelativeLayout>