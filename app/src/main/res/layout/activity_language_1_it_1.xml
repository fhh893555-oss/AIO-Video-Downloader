<?xml version="1.0" encoding="utf-8"?>
<com.github.dangiashish.StyledCardView
  xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  xmlns:tools="http://schemas.android.com/tools"
  android:id="@+id/language_item_card"
  android:layout_width="match_parent"
  android:layout_height="wrap_content"
  android:layout_margin="@dimen/_5"
  app:background_Color="@color/color_card"
  app:background_Type="fill_stroke"
  app:cornerRadius="@dimen/default_radius"
  app:stroke_Color="@color/color_card_stroke"
  app:stroke_ColorType="solid"
  app:stroke_Width="@dimen/_1">

  <RelativeLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <ImageView
      android:id="@+id/language_flag_image"
      android:layout_width="match_parent"
      android:layout_height="match_parent"
      android:layout_alignParentRight="true"
      android:layout_alignParentBottom="true"
      android:adjustViewBounds="true"
      android:alpha=".5"
      android:importantForAccessibility="no"
      android:scaleType="centerCrop"

      tools:ignore="ImageContrastCheck" />

    <TextView
      android:id="@+id/language_name_text"
      style="@style/style_textviews"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_margin="@dimen/_10"
      android:fontFamily="@font/font_family_medium"
      android:shadowColor="@color/color_primary"
      android:text="@string/title__"
      android:textColor="@color/color_text_primary"
      android:textSize="@dimen/message_text_size"
      tools:ignore="SpUsage,TextContrastCheck,VisualLintSystemUi,TextSizeCheck" />
  </RelativeLayout>
</com.github.dangiashish.StyledCardView>