  ~
  ~ Layout for feedback action buttons and footer. This component provides
  ~ the primary send button, a clear attachment button (shown conditionally),
  ~ and a footer note indicating that feedback is secure and encrypted.
  ~
  ~ The layout includes:
  ~   - Send Feedback button (filled, with email icon)
  ~   - Clear Attachment button (outlined, with delete icon, initially hidden)
  ~   - Security footer (shield icon + text)
  -->
<LinearLayout
  xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  xmlns:tools="http://schemas.android.com/tools"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:orientation="vertical">

  <!-- Primary send feedback button -->
  <com.google.android.material.button.MaterialButton
    android:id="@+id/btnSendReport"
    style="@style/Widget.Material3.Button.IconButton.Filled"
    android:layout_width="match_parent"
    android:layout_height="52dp"
    android:fontFamily="@font/font_family_medium"
    android:text="@string/btn_send_feedback"
    android:textAllCaps="false"
    android:textSize="@dimen/normal_text_size"
    app:backgroundTint="@color/style_color_button_primary"
    app:cornerRadius="5dp"
    app:icon="@drawable/ic_send_email"
    app:iconGravity="textStart"
    app:iconPadding="10dp"
    app:iconSize="24dp"
    tools:ignore="SpUsage,VisualLintButtonSize,TextSizeCheck" />

  <!-- Clear attachment button (visible only when a screenshot is attached) -->
  <com.google.android.material.button.MaterialButton
    android:id="@+id/btnClearAttachment"
    style="@style/Widget.Material3.Button.IconButton.Outlined"
    android:layout_width="match_parent"
    android:layout_height="52dp"
    android:fontFamily="@font/font_family_medium"
    android:text="@string/btn_clear_attachment"
    android:textColor="@color/style_color_button_outline"
    android:textSize="@dimen/normal_text_size"
    android:visibility="gone"
    app:cornerRadius="5dp"
    app:icon="@drawable/ic_delete"
    app:iconGravity="textStart"
    app:iconPadding="10dp"
    app:iconSize="24dp"
    app:iconTint="@color/style_color_button_primary"
    app:strokeColor="@color/style_color_button_outline"
    app:strokeWidth="1dp"

    tools:ignore="SpUsage,VisualLintButtonSize,TextSizeCheck"
    tools:visibility="visible" />

  <!-- Security footer indicating feedback is safe and encrypted -->
  <LinearLayout
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_gravity="center_horizontal"
    android:layout_marginTop="2dp"
    android:orientation="horizontal">

    <!-- Shield lock icon -->
    <com.google.android.material.imageview.ShapeableImageView
      android:layout_width="13dp"
      android:layout_height="13dp"
      android:layout_gravity="center_vertical"
      android:layout_marginRight="5dp"
      android:adjustViewBounds="true"
      android:src="@drawable/ic_shield_lock_fill"
      android:tint="@color/style_color_text_hint"
      tools:ignore="ImageContrastCheck" />

    <!-- Security assurance text -->
    <com.google.android.material.textview.MaterialTextView
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_gravity="center_vertical"
      android:fontFamily="@font/font_family_light"
      android:gravity="center_vertical"
      android:text="@string/footer_feedback_safe"
      android:textColor="@color/style_color_text_hint"
      android:textSize="@dimen/small_text_size"
      tools:ignore="SpUsage,TextSizeCheck,TextContrastCheck" />
  </LinearLayout>
</LinearLayout>