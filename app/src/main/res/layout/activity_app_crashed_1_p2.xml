<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:ignore="SpUsage,UseCompatTextViewDrawableXml,
    TextSizeCheck,TouchTargetSizeCheck">

    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/btnTechnicalDetails"
        android:layout_width="wrap_content"
        android:layout_height="30dp"
        android:layout_gravity="center_horizontal"
        android:background="@drawable/bg_button_negative"
        android:clickable="true"
        android:drawableRight="@drawable/ic_arrow_down"
        android:drawablePadding="5dp"
        android:drawableTint="@color/style_color_button_primary"
        android:fontFamily="@font/font_family_medium"
        android:gravity="center"
        android:paddingLeft="10dp"
        android:paddingRight="5dp"
        android:text="@string/label_view_technical_details"
        android:textColor="@color/style_color_button_primary"
        android:textSize="@dimen/normal_text_size"
        tools:ignore="TextSizeCheck,TouchTargetSizeCheck" />

    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/txtStacktrace"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="5dp"
        android:background="@drawable/bg_stacktrace"
        android:ellipsize="end"
        android:fontFamily="@font/font_family_regular"
        android:maxLength="800"
        android:padding="10dp"
        android:textColor="@color/style_color_text_secondary"
        android:textIsSelectable="true"
        android:textSize="@dimen/small_text_size"
        android:visibility="gone"
        tools:ignore="HardcodedText,SpUsage,TextSizeCheck"
        tools:text="java.lang.NullPointerException..."
        tools:visibility="visible" />

</LinearLayout>