  ~
  ~ Layout for the action buttons section in the language selection screen.
  ~ This component provides two buttons for the user:
  ~   - Continue: Applies the selected language and proceeds to the next screen.
  ~   - Skip for Now: Bypasses language selection and proceeds with default locale.
  ~
  ~ The Continue button uses a filled style with a checkmark icon.
  ~ The Skip button uses an outlined style with a right arrow icon.
  -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
              xmlns:app="http://schemas.android.com/apk/res-auto"
              xmlns:tools="http://schemas.android.com/tools"
              android:layout_width="match_parent"
              android:layout_height="match_parent"
              android:orientation="vertical">

  <!-- Primary button: Continue with selected language -->
  <com.google.android.material.button.MaterialButton
    android:id="@+id/btnContinue"
    style="@style/Widget.Material3.Button.IconButton.Filled"
    android:layout_width="match_parent"
    android:layout_height="52dp"
    android:fontFamily="@font/font_family_medium"
    android:text="@string/label_continue"
    android:textAllCaps="false"
    android:textSize="@dimen/normal_text_size"
    app:backgroundTint="@color/style_color_button_primary"
    app:cornerRadius="5dp"
    app:icon="@drawable/ic_okay_check"
    app:iconGravity="textStart"
    app:iconPadding="10dp"
    app:iconSize="24dp"
    tools:ignore="SpUsage,VisualLintButtonSize,TextSizeCheck" />

  <!-- Secondary button: Skip language selection -->
  <com.google.android.material.button.MaterialButton
    android:id="@+id/btnSkipForNow"
    style="@style/Widget.Material3.Button.IconButton.Outlined"
    android:layout_width="match_parent"
    android:layout_height="52dp"
    android:fontFamily="@font/font_family_medium"
    android:text="@string/label_skip_for_now"
    android:textColor="@color/style_color_button_outline"
    android:textSize="@dimen/normal_text_size"
    app:cornerRadius="5dp"
    app:icon="@drawable/ic_keyboard_arrow_right"
    app:iconGravity="textStart"
    app:iconPadding="10dp"
    app:iconSize="24dp"
    app:iconTint="@color/style_color_button_primary"
    app:strokeColor="@color/style_color_button_outline"
    app:strokeWidth="1dp"
    tools:ignore="SpUsage,VisualLintButtonSize,TextSizeCheck" />
</LinearLayout>