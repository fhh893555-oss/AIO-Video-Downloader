<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
  xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  xmlns:tools="http://schemas.android.com/tools"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:orientation="vertical">

  <com.google.android.material.card.MaterialCardView
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="@color/style_color_card"
    app:cardCornerRadius="5dp"
    app:strokeColor="@color/style_color_card_stroke"
    app:strokeWidth="1dp">

    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:orientation="vertical"
      android:padding="10dp"
      tools:ignore="UselessLeaf">

      <LinearLayout
        android:id="@+id/btnEnableCrashReport"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:background="@drawable/bg_button_negative"
        android:clickable="true"
        android:orientation="horizontal">

        <androidx.appcompat.widget.AppCompatImageView
          android:layout_width="30dp"
          android:layout_height="30dp"
          android:layout_gravity="center_vertical"
          android:layout_marginLeft="5dp"
          android:layout_marginTop="5dp"
          android:layout_marginRight="10dp"
          android:layout_marginBottom="5dp"
          android:adjustViewBounds="true"
          android:background="@drawable/bg_color_circle"
          android:backgroundTint="@color/style_color_primary_light"
          android:padding="5dp"
          android:scaleType="centerInside"
          android:tint="@color/style_color_icon"
          app:srcCompat="@drawable/ic_pest_control" />

        <LinearLayout
          android:layout_width="0dp"
          android:layout_height="wrap_content"
          android:layout_gravity="center_vertical"
          android:layout_weight="1"
          android:orientation="vertical">

          <com.google.android.material.textview.MaterialTextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/font_family_medium"
            android:text="@string/label_crash_report"
            android:textColor="@color/style_color_text_primary"
            android:textSize="@dimen/normal_text_size"
            tools:ignore="SpUsage" />

          <com.google.android.material.textview.MaterialTextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/font_family_regular"
            android:text="@string/desc_crash_report"
            android:textColor="@color/style_color_text_secondary"
            android:textSize="@dimen/small_text_size"
            tools:ignore="SpUsage" />
        </LinearLayout>

        <ImageView
          android:id="@+id/ivCrashReport"
          android:layout_width="20dp"
          android:layout_height="20dp"
          android:layout_gravity="center_vertical"
          android:layout_marginLeft="5dp"
          android:layout_marginRight="5dp"
          android:importantForAccessibility="no"
          android:src="@drawable/ic_uncheck_box"
          android:tint="@color/style_color_icon"
          tools:ignore="UseAppTint" />
      </LinearLayout>

      <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="5dp"
        android:layout_marginBottom="5dp"
        android:background="@color/style_color_divider" />

      <LinearLayout
        android:id="@+id/btnEnableAnalytics"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:background="@drawable/bg_button_negative"
        android:clickable="true"
        android:orientation="horizontal">

        <androidx.appcompat.widget.AppCompatImageView
          android:layout_width="30dp"
          android:layout_height="30dp"
          android:layout_gravity="center_vertical"
          android:layout_marginLeft="5dp"
          android:layout_marginTop="5dp"
          android:layout_marginRight="10dp"
          android:layout_marginBottom="5dp"
          android:adjustViewBounds="true"
          android:background="@drawable/bg_color_circle"
          android:backgroundTint="@color/style_color_primary_light"
          android:padding="5dp"
          android:scaleType="centerInside"
          android:tint="@color/style_color_icon"
          app:srcCompat="@drawable/ic_analytics" />

        <LinearLayout
          android:layout_width="0dp"
          android:layout_height="wrap_content"
          android:layout_gravity="center_vertical"
          android:layout_weight="1"
          android:orientation="vertical">

          <com.google.android.material.textview.MaterialTextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/font_family_medium"
            android:text="@string/label_analytics"
            android:textColor="@color/style_color_text_primary"
            android:textSize="@dimen/normal_text_size"
            tools:ignore="SpUsage" />

          <com.google.android.material.textview.MaterialTextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/font_family_regular"
            android:text="@string/desc_usage_analytics"
            android:textColor="@color/style_color_text_secondary"
            android:textSize="@dimen/small_text_size"
            tools:ignore="SpUsage" />
        </LinearLayout>

        <ImageView
          android:id="@+id/ivEnableAnalytics"
          android:layout_width="20dp"
          android:layout_height="20dp"
          android:layout_gravity="center_vertical"
          android:layout_marginLeft="5dp"
          android:layout_marginRight="5dp"
          android:importantForAccessibility="no"
          android:src="@drawable/ic_uncheck_box"
          android:tint="@color/style_color_icon"
          tools:ignore="UseAppTint" />
      </LinearLayout>

      <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="5dp"
        android:layout_marginBottom="5dp"
        android:background="@color/style_color_divider" />

      <LinearLayout
        android:id="@+id/btnRecommendations"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:background="@drawable/bg_button_negative"
        android:clickable="true"
        android:orientation="horizontal">

        <androidx.appcompat.widget.AppCompatImageView
          android:layout_width="30dp"
          android:layout_height="30dp"
          android:layout_gravity="center_vertical"
          android:layout_marginLeft="5dp"
          android:layout_marginTop="5dp"
          android:layout_marginRight="10dp"
          android:layout_marginBottom="5dp"
          android:adjustViewBounds="true"
          android:background="@drawable/bg_color_circle"
          android:backgroundTint="@color/style_color_primary_light"
          android:padding="5dp"
          android:scaleType="centerInside"
          android:tint="@color/style_color_icon"
          app:srcCompat="@drawable/ic_star_shine" />

        <LinearLayout
          android:layout_width="0dp"
          android:layout_height="wrap_content"
          android:layout_gravity="center_vertical"
          android:layout_weight="1"
          android:orientation="vertical">

          <com.google.android.material.textview.MaterialTextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/font_family_medium"
            android:text="@string/label_personalized_rec"
            android:textColor="@color/style_color_text_primary"
            android:textSize="@dimen/normal_text_size"
            tools:ignore="SpUsage" />

          <com.google.android.material.textview.MaterialTextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/font_family_regular"
            android:text="@string/desc_personalized_rec"
            android:textColor="@color/style_color_text_secondary"
            android:textSize="@dimen/small_text_size"
            tools:ignore="SpUsage" />
        </LinearLayout>

        <ImageView
          android:id="@+id/ivRecommendations"
          android:layout_width="20dp"
          android:layout_height="20dp"
          android:layout_gravity="center_vertical"
          android:layout_marginLeft="5dp"
          android:layout_marginRight="5dp"
          android:importantForAccessibility="no"
          android:src="@drawable/ic_uncheck_box"
          android:tint="@color/style_color_icon"
          tools:ignore="UseAppTint" />
      </LinearLayout>

    </LinearLayout>
  </com.google.android.material.card.MaterialCardView>
</LinearLayout>