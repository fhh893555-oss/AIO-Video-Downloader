<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
  xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:tools="http://schemas.android.com/tools"
  android:layout_width="match_parent"
  android:layout_height="wrap_content"
  android:layout_marginLeft="@dimen/_5"
  android:layout_marginTop="@dimen/_5"
  android:layout_marginRight="@dimen/_5"
  android:layout_marginBottom="@dimen/_5"
  android:orientation="horizontal"
  tools:ignore="ContentDescription,HardcodedText,ImageContrastCheck,
    RtlHardcoded,SmallSp,SpeakableTextPresentCheck,TouchTargetSizeCheck,UseAppTint,
    UseCompatTextViewDrawableXml,UselessLeaf, TextContrastCheck">

  <TextView
    style="@style/style_textviews"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_centerVertical="true"
    android:layout_toLeftOf="@+id/homepage_storage_permission_allow_button"
    android:drawableLeft="@drawable/ic_database_storage"
    android:drawablePadding="@dimen/_5"
    android:drawableTint="@color/color_error"
    android:fontFamily="@font/font_family_italic"
    android:maxLines="3"
    android:singleLine="false"
    android:text="@string/text_onetime_storage_setup"
    android:textSize="@dimen/small_text_size"
    tools:ignore="VisualLintSystemUi" />

  <TextView
    android:id="@+id/homepage_storage_permission_allow_button"
    style="@style/style_text_button"
    android:layout_width="wrap_content"
    android:layout_height="@dimen/_35"
    android:layout_alignParentRight="true"
    android:layout_centerVertical="true"
    android:background="@drawable/ic_button_secondary_selector"
    android:drawableLeft="@drawable/ic_task_allow_small"
    android:drawableTint="@color/color_on_secondary"
    android:fontFamily="@font/font_family_semibold"
    android:paddingLeft="@dimen/_5"
    android:paddingRight="@dimen/_8"
    android:text="@string/title_allow_now"
    android:textColor="@color/color_on_secondary"
    tools:ignore="TextContrastCheck,TouchTargetSizeCheck,VisualLintSystemUi" />

</RelativeLayout>