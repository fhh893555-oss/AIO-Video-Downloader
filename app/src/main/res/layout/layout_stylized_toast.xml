<?xml version="1.0" encoding="utf-8"?>
<com.github.dangiashish.StyledCardView
  xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  xmlns:tools="http://schemas.android.com/tools"
  android:layout_width="wrap_content"
  android:layout_height="wrap_content"
  android:layout_gravity="center_horizontal"
  app:background_ColorType="gradient_linear"
  app:background_Gradient_Angle="45"
  app:background_Gradient_Color0="@color/color_card"
  app:background_Gradient_Color1="@color/color_surface"
  app:background_Type="fill_stroke"
  app:cornerRadius="@dimen/default_radius"
  app:shadow0_Outer_Alpha=".1"
  app:shadow0_Outer_Angle="-45"
  app:shadow0_Outer_Blur="@dimen/_5"
  app:shadow0_Outer_Color="@color/color_text_primary"
  app:shadow0_Outer_Distance="@dimen/_5"
  app:shadow1_Outer_Alpha="0.1"
  app:shadow1_Outer_Angle="360"
  app:shadow1_Outer_Blur="@dimen/_5"
  app:shadow1_Outer_Color="@color/color_text_hint"
  app:shadow1_Outer_Distance="@dimen/_2"
  app:shadow_Outer_Area="@dimen/_10"
  app:stroke_Alpha=".2"
  app:stroke_ColorType="gradient_sweep"
  app:stroke_Gradient_Angle="-45"
  app:stroke_Gradient_Color0="@color/color_text_primary"
  app:stroke_Gradient_Color1="@color/color_text_primary"
  app:stroke_Width="0.5dp">

  <LinearLayout
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginStart="@dimen/_0"
    android:layout_marginLeft="@dimen/_0"
    android:layout_marginTop="@dimen/_0"
    android:layout_marginEnd="@dimen/_0"
    android:layout_marginRight="@dimen/_0"
    android:layout_marginBottom="@dimen/_0"
    android:orientation="horizontal"
    android:paddingStart="@dimen/_0"
    android:paddingLeft="@dimen/_0"
    android:paddingTop="@dimen/_0"
    android:paddingEnd="@dimen/_0"
    android:paddingRight="@dimen/_0"
    android:paddingBottom="@dimen/_0">

    <ImageView
      android:id="@+id/imgIcon"
      android:layout_width="@dimen/_40"
      android:layout_height="wrap_content"
      android:layout_gravity="center_vertical"
      android:layout_marginLeft="@dimen/_10"
      android:adjustViewBounds="true"
      android:importantForAccessibility="no"
      android:scaleType="fitXY"
      android:src="@drawable/img_information"
      tools:ignore="ImageContrastCheck" />

    <TextView
      android:id="@+id/txLabel"
      style="@style/style_textviews"
      android:layout_width="wrap_content"
      android:layout_height="@dimen/_50"
      android:layout_gravity="center_vertical"
      android:layout_marginLeft="@dimen/_10"
      android:layout_marginTop="@dimen/_5"
      android:layout_marginRight="@dimen/_20"
      android:layout_marginBottom="@dimen/_5"
      android:ellipsize="end"
      android:fontFamily="@font/font_family_regular"
      android:gravity="center_vertical"
      android:maxLines="1"
      android:singleLine="true"
      android:text="@string/label_sample_text_message"
      android:textColor="@color/color_text_primary"
      android:textSize="@dimen/message_text_size"
      tools:ignore="SpUsage,TextSizeCheck,VisualLintSystemUi" />
  </LinearLayout>

</com.github.dangiashish.StyledCardView>