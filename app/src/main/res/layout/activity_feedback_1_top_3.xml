<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
  xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  xmlns:tools="http://schemas.android.com/tools"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:orientation="vertical">

  <com.github.dangiashish.StyledCardView
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:background_ColorType="gradient_linear"
    app:background_Gradient_Angle="45"
    app:background_Gradient_Color0="@color/color_card"
    app:background_Gradient_Color1="@color/color_surface"
    app:background_Type="fill_stroke"
    app:cornerRadius="@dimen/default_radius"
    app:shadow0_Outer_Alpha=".1"
    app:shadow0_Outer_Angle="-45"
    app:shadow0_Outer_Blur="@dimen/_5"
    app:shadow0_Outer_Color="@color/color_primary_variant"
    app:shadow0_Outer_Distance="@dimen/_5"
    app:shadow1_Outer_Alpha="0.1"
    app:shadow1_Outer_Angle="360"
    app:shadow1_Outer_Blur="@dimen/_5"
    app:shadow1_Outer_Color="@color/color_secondary"
    app:shadow1_Outer_Distance="@dimen/_2"
    app:shadow_Outer_Area="@dimen/_10"
    app:stroke_Alpha=".3"
    app:stroke_ColorType="gradient_sweep"
    app:stroke_Gradient_Angle="-45"
    app:stroke_Gradient_Color0="@color/color_primary"
    app:stroke_Gradient_Color1="@color/color_primary_variant"
    app:stroke_Width="1dp">

    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:orientation="vertical"
      android:paddingLeft="@dimen/_15"
      android:paddingTop="@dimen/_15"
      android:paddingRight="@dimen/_15"
      android:paddingBottom="@dimen/_15">

      <TextView
        style="@style/style_textviews"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/_0"
        android:fontFamily="@font/font_family_bold"
        android:text="@string/label_subject"
        android:textColor="@color/color_text_primary"
        android:textSize="@dimen/message_text_size"
        tools:ignore="SpUsage,TextSizeCheck,VisualLintSystemUi" />

      <com.github.dangiashish.StyledCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/_10"
        app:background_Color="@color/color_edit_background"
        app:background_Type="fill_stroke"
        app:cornerRadius="@dimen/default_radius"
        app:shadow0_Inner_Alpha=".1"
        app:shadow0_Inner_Angle="45"
        app:shadow0_Inner_Blur="@dimen/_2"
        app:shadow0_Inner_Color="@color/color_text_hint"
        app:shadow1_Inner_Distance="@dimen/_2"
        app:stroke_Alpha="1"
        app:stroke_Color="@color/color_card_stroke"
        app:stroke_Width="0.5dp">

        <RelativeLayout
          android:layout_width="match_parent"
          android:layout_height="wrap_content">

          <EditText
            android:id="@+id/editSubject"
            style="@style/style_edittext"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/_30"
            android:layout_alignParentLeft="true"
            android:layout_centerVertical="true"
            android:layout_toLeftOf="@id/btnPasteIcon"
            android:drawableLeft="@null"
            android:gravity="center_vertical"
            android:hint="@string/hint_subject"
            android:importantForAutofill="no"
            android:inputType="text"
            android:paddingLeft="@dimen/_5"
            android:textAlignment="textStart"
            android:textSize="@dimen/message_text_size"
            tools:ignore="SpUsage,TextSizeCheck,TextContrastCheck,
            TouchTargetSizeCheck, VisualLintTextFieldSize,VisualLintTextFieldSize" />

          <RelativeLayout
            android:id="@+id/btnPasteIcon"
            android:layout_width="@dimen/_20"
            android:layout_height="@dimen/_20"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"
            android:layout_marginLeft="@dimen/_0"
            android:layout_marginTop="@dimen/_5"
            android:layout_marginRight="@dimen/_10"
            android:layout_marginBottom="@dimen/_5"
            android:background="@drawable/bg_button_negative"
            android:clickable="true"
            tools:ignore="SpeakableTextPresentCheck,TouchTargetSizeCheck">

            <ImageView
              android:layout_width="@dimen/_18"
              android:layout_height="@dimen/_18"
              android:layout_centerInParent="true"
              android:adjustViewBounds="true"
              android:alpha=".7"
              android:src="@drawable/ic_paste_text"
              android:tint="@color/color_text_hint"
              tools:ignore="ContentDescription,UseAppTint,ImageContrastCheck" />
          </RelativeLayout>
        </RelativeLayout>

      </com.github.dangiashish.StyledCardView>

      <TextView
        style="@style/style_textviews"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/_0"
        android:layout_marginTop="@dimen/_20"
        android:layout_marginRight="@dimen/_10"
        android:layout_marginBottom="@dimen/_0"
        android:fontFamily="@font/font_family_bold"
        android:text="@string/label_describe_feedback"
        android:textColor="@color/color_text_primary"
        android:textSize="@dimen/message_text_size"
        tools:ignore="SpUsage,TextSizeCheck" />

      <com.github.dangiashish.StyledCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/_10"
        app:background_Color="@color/color_edit_background"
        app:background_Type="fill_stroke"
        app:cornerRadius="@dimen/default_radius"
        app:shadow0_Inner_Alpha=".1"
        app:shadow0_Inner_Angle="45"
        app:shadow0_Inner_Blur="@dimen/_2"
        app:shadow0_Inner_Color="@color/color_text_hint"
        app:shadow1_Inner_Distance="@dimen/_2"
        app:stroke_Alpha="1"
        app:stroke_Color="@color/color_card_stroke"
        app:stroke_Width="0.5dp">

        <FrameLayout
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:orientation="vertical">

          <EditText
            android:id="@+id/editFeedback"
            style="@style/style_edittext"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:drawableLeft="@null"
            android:gravity="left"
            android:hint="@string/hint_describe_feedback"
            android:importantForAutofill="no"
            android:inputType="textMultiLine"
            android:maxLines="5"
            android:minLines="5"
            android:paddingLeft="@dimen/_5"
            android:paddingRight="@dimen/_5"
            android:singleLine="false"
            android:textSize="@dimen/message_text_size"
            tools:ignore="SpUsage,TextSizeCheck,TextContrastCheck,
            VisualLintTextFieldSize,VisualLintTextFieldSize" />

          <TextView
            android:id="@+id/tvCharCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="right|bottom"
            android:layout_marginRight="@dimen/_10"
            android:layout_marginBottom="@dimen/_5"
            android:background="@drawable/ic_rd_edit_bg_color"
            android:gravity="right|bottom"
            android:paddingLeft="@dimen/_5"
            android:paddingTop="@dimen/_2"
            android:paddingRight="@dimen/_5"
            android:paddingBottom="@dimen/_2"
            android:text="@string/title_zero_slash_five_hundred"
            android:textColor="@color/color_text_secondary"
            android:textSize="@dimen/smaller_text_size"
            tools:ignore="SpUsage,TextSizeCheck" />
        </FrameLayout>
      </com.github.dangiashish.StyledCardView>

      <TextView
        style="@style/style_textviews"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/_0"
        android:layout_marginTop="@dimen/_20"
        android:layout_marginRight="@dimen/_10"
        android:layout_marginBottom="@dimen/_0"
        android:fontFamily="@font/font_family_bold"
        android:text="@string/label_attach_screenshot"
        android:textColor="@color/color_text_primary"
        android:textSize="@dimen/message_text_size"
        tools:ignore="SpUsage,TextSizeCheck" />

      <com.github.dangiashish.StyledCardView
        android:id="@+id/contUploadPic"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/_10"
        app:background_Color="@color/color_background"
        app:background_ColorType="solid"
        app:background_Type="fill_stroke"
        app:cornerRadius="@dimen/default_radius"
        app:stroke_Alpha=".7"
        app:stroke_CapType="round"
        app:stroke_Color="@color/color_primary_variant"
        app:stroke_DashSize="@dimen/_5"
        app:stroke_GapSize="@dimen/_3"
        app:stroke_Type="dash"
        app:stroke_Width=".5dp">

        <LinearLayout
          android:id="@+id/btnUploadPic"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:background="@drawable/bg_button_negative"
          android:clickable="true"
          android:gravity="center"
          android:orientation="vertical"
          android:padding="@dimen/_20">

          <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal"
            tools:ignore="UseCompoundDrawables">

            <ImageView
              android:layout_width="@dimen/_20"
              android:layout_height="wrap_content"
              android:adjustViewBounds="true"
              android:src="@drawable/ic_cloud_upload"
              android:tint="@color/color_primary"
              tools:ignore="ContentDescription,UseAppTint" />

            <TextView
              style="@style/style_textviews"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:layout_margin="@dimen/_0"
              android:fontFamily="@font/font_family_medium"
              android:paddingLeft="@dimen/_5"
              android:paddingRight="@dimen/_5"
              android:text="@string/label_upload_image"
              android:textColor="@color/color_primary"
              android:textSize="@dimen/message_text_size"
              tools:ignore="SpUsage,TextSizeCheck,TextContrastCheck" />
          </LinearLayout>

          <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_5"
            android:text="@string/label_upload_image_hint"
            android:textColor="@color/color_text_hint"
            android:textSize="@dimen/smaller_text_size"
            tools:ignore="SpUsage,TextSizeCheck,TextContrastCheck" />
        </LinearLayout>
      </com.github.dangiashish.StyledCardView>

      <com.github.dangiashish.StyledCardView
        android:id="@+id/contAttachmentSelected"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/_10"
        android:visibility="visible"
        app:background_Color="@color/color_accent_variant_2"
        app:background_ColorType="solid"
        app:background_Type="fill_stroke"
        app:cornerRadius="@dimen/default_radius"
        app:stroke_Alpha=".7"
        app:stroke_CapType="round"
        app:stroke_Color="@color/color_accent_variant"
        app:stroke_DashSize="@dimen/_5"
        app:stroke_GapSize="@dimen/_3"
        app:stroke_Type="dash"
        app:stroke_Width=".5dp"
        tools:ignore="DuplicateClickableBoundsCheck">

        <FrameLayout
          android:id="@+id/btnCancelUpload"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:background="@drawable/bg_button_negative"
          android:clickable="true">

          <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="@dimen/_20">

            <LinearLayout
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:gravity="center"
              android:orientation="horizontal"
              tools:ignore="UseCompoundDrawables">

              <ImageView
                android:layout_width="@dimen/_18"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_marginRight="@dimen/_5"
                android:adjustViewBounds="true"
                android:src="@drawable/ic_file_present"
                android:tint="@color/color_accent_variant"
                tools:ignore="ContentDescription,UseAppTint,ImageContrastCheck" />

              <TextView
                android:id="@+id/txtFileAttch"
                style="@style/style_textviews"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_margin="@dimen/_0"
                android:fontFamily="@font/font_family_bold"
                android:text="@string/label_file_sample_name"
                android:textColor="@color/color_accent_variant"
                android:textSize="@dimen/message_text_size"
                tools:ignore="SpUsage,TextSizeCheck,TextContrastCheck" />
            </LinearLayout>

            <TextView
              android:id="@+id/txtFileSize"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:layout_marginTop="@dimen/_5"
              android:fontFamily="@font/font_family_medium"
              android:text="@string/label_sample_file_size"
              android:textColor="@color/color_text_hint"
              android:textSize="@dimen/smaller_text_size"
              tools:ignore="SpUsage,TextSizeCheck,TextContrastCheck" />

            <TextView
              style="@style/style_textviews"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:layout_gravity="center_horizontal"
              android:layout_marginLeft="@dimen/_5"
              android:layout_marginTop="@dimen/_5"
              android:layout_marginRight="@dimen/_5"
              android:layout_marginBottom="@dimen/_0"
              android:fontFamily="@font/font_family_regular"
              android:text="@string/hint_click_again_for_changing_attachment"
              android:textColor="@color/color_text_primary"
              android:textSize="@dimen/smaller_text_size"
              tools:ignore="SpUsage,TextSizeCheck,TextContrastCheck" />
          </LinearLayout>

          <ImageView
            android:id="@+id/btnCancel"
            android:layout_width="@dimen/_15"
            android:layout_height="@dimen/_15"
            android:layout_gravity="top|right"
            android:layout_margin="@dimen/_5"
            android:background="@drawable/ic_rd_accent_var_color"
            android:importantForAccessibility="no"
            android:src="@drawable/ic_cancel_circle"
            android:tint="@color/color_surface"
            tools:ignore="UseAppTint,ImageContrastCheck" />

        </FrameLayout>
      </com.github.dangiashish.StyledCardView>

      <TextView
        style="@style/style_textviews"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/_0"
        android:layout_marginTop="@dimen/_20"
        android:layout_marginRight="@dimen/_10"
        android:layout_marginBottom="@dimen/_0"
        android:fontFamily="@font/font_family_bold"
        android:text="@string/label_email"
        android:textColor="@color/color_text_primary"
        android:textSize="@dimen/message_text_size"
        tools:ignore="SpUsage,TextSizeCheck" />

      <com.github.dangiashish.StyledCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/_10"
        app:background_Color="@color/color_edit_background"
        app:background_Type="fill_stroke"
        app:cornerRadius="@dimen/default_radius"
        app:shadow0_Inner_Alpha=".1"
        app:shadow0_Inner_Angle="45"
        app:shadow0_Inner_Blur="@dimen/_2"
        app:shadow0_Inner_Color="@color/color_text_hint"
        app:shadow1_Inner_Distance="@dimen/_2"
        app:stroke_Alpha="1"
        app:stroke_Color="@color/color_card_stroke"
        app:stroke_Width="0.5dp">

        <RelativeLayout
          android:layout_width="match_parent"
          android:layout_height="wrap_content">

          <RelativeLayout
            android:id="@+id/imgMail"
            android:layout_width="@dimen/_20"
            android:layout_height="@dimen/_20"
            android:layout_alignParentLeft="true"
            android:layout_centerVertical="true"
            android:layout_marginLeft="@dimen/_10"
            android:layout_marginTop="@dimen/_5"
            android:layout_marginRight="@dimen/_2"
            android:layout_marginBottom="@dimen/_5"
            tools:ignore="SpeakableTextPresentCheck,TouchTargetSizeCheck">

            <ImageView
              android:layout_width="@dimen/_18"
              android:layout_height="@dimen/_18"
              android:layout_centerInParent="true"
              android:adjustViewBounds="true"
              android:alpha=".7"
              android:src="@drawable/ic_email_box"
              android:tint="@color/color_text_hint"
              tools:ignore="ContentDescription,UseAppTint,ImageContrastCheck" />
          </RelativeLayout>

          <EditText
            android:id="@+id/editEmail"
            style="@style/style_edittext"
            android:layout_width="match_parent"
            android:layout_height="@dimen/_30"
            android:layout_centerVertical="true"
            android:layout_toRightOf="@id/imgMail"
            android:drawableLeft="@null"
            android:gravity="center_vertical"
            android:hint="@string/hint_email"
            android:importantForAutofill="no"
            android:inputType="textEmailAddress"
            android:paddingLeft="@dimen/_0"
            android:paddingRight="@dimen/_10"
            android:textAlignment="textStart"
            android:textSize="@dimen/message_text_size"
            tools:ignore="SpUsage,TextSizeCheck,TextContrastCheck,
            TouchTargetSizeCheck, VisualLintTextFieldSize,VisualLintTextFieldSize" />
        </RelativeLayout>
      </com.github.dangiashish.StyledCardView>

      <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/_5"
        android:layout_marginTop="@dimen/_5"
        android:text="@string/subtext_email"
        android:textColor="@color/color_text_hint"
        android:textSize="@dimen/small_text_size"
        tools:ignore="SpUsage,TextSizeCheck,TextContrastCheck" />

      <RelativeLayout
        android:id="@+id/btnSendFeedback"
        android:layout_width="match_parent"
        android:layout_height="@dimen/_40"
        android:layout_marginLeft="@dimen/_10"
        android:layout_marginTop="@dimen/_20"
        android:layout_marginRight="@dimen/_10"
        android:layout_marginBottom="@dimen/_10"
        android:background="@drawable/bg_button_gradient"
        android:clickable="true"
        android:elevation="@dimen/_2"
        android:focusable="true"
        tools:ignore="TouchTargetSizeCheck">

        <TextView
          style="@style/style_textviews"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:layout_centerInParent="true"
          android:drawableRight="@drawable/ic_send_email"
          android:drawablePadding="@dimen/_10"
          android:drawableTint="@color/color_surface"
          android:fontFamily="@font/font_family_bold"
          android:shadowColor="@color/color_primary"
          android:shadowDx="1"
          android:shadowDy="1"
          android:shadowRadius=".1"
          android:text="@string/btn_send_feedback"
          android:textColor="@color/color_surface"
          android:textSize="@dimen/normal_text_size"
          tools:ignore="RelativeOverlap,SpUsage,UseCompatTextViewDrawableXml,
          TextSizeCheck,TextContrastCheck" />
      </RelativeLayout>

      <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="@dimen/_5"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        tools:ignore="UseCompoundDrawables">

        <ImageView
          android:layout_width="@dimen/_16"
          android:layout_height="@dimen/_16"
          android:layout_gravity="center_vertical"
          android:alpha=".5"
          android:src="@drawable/ic_secure_badge"
          tools:ignore="ContentDescription,ImageContrastCheck" />

        <TextView
          style="@style/style_textviews"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:layout_gravity="center_vertical"
          android:layout_marginLeft="@dimen/_5"
          android:layout_marginTop="@dimen/_0"
          android:layout_marginRight="@dimen/_5"
          android:layout_marginBottom="@dimen/_0"
          android:text="@string/footer_feedback_safe"
          android:textColor="@color/color_text_hint"
          android:textSize="@dimen/smaller_text_size"
          tools:ignore="SpUsage,TextSizeCheck,TextContrastCheck" />
      </LinearLayout>
    </LinearLayout>
  </com.github.dangiashish.StyledCardView>
</LinearLayout>