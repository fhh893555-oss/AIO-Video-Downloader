<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
            xmlns:app="http://schemas.android.com/apk/res-auto"
            xmlns:tools="http://schemas.android.com/tools"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/style_color_background"
            android:fitsSystemWindows="true"
            android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <FrameLayout
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="15dp"
            android:layout_marginBottom="10dp"
            tools:ignore="UselessParent">

            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_error_circle" />

            <com.google.android.material.imageview.ShapeableImageView
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_gravity="center"
                android:importantForAccessibility="no"
                android:src="@drawable/ic_warning_fill"
                android:tint="@color/color_error"
                tools:ignore="UseAppTint" />
        </FrameLayout>

        <com.google.android.material.textview.MaterialTextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:fontFamily="@font/font_family_bold"
            android:text="@string/label_app_crashed"
            android:textColor="@color/style_color_text_primary"
            android:textSize="@dimen/title_text_size"
            tools:ignore="SpUsage,TextSizeCheck" />

        <com.google.android.material.textview.MaterialTextView
            android:layout_width="300dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="5dp"
            android:fontFamily="@font/font_family_regular"
            android:gravity="center"
            android:text="@string/desc_an_unexpected_error_occurred"
            android:textColor="@color/style_color_text_secondary"
            android:textSize="@dimen/sub_heading_text_size_v2"
            tools:ignore="SpUsage,TextSizeCheck" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/inputLayout"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="20dp"
            android:layout_marginTop="20dp"
            android:layout_marginRight="20dp"
            android:hint="@string/label_what_were_you_doing_optional"
            app:boxBackgroundColor="@color/style_color_input_background"
            app:boxBackgroundMode="outline"
            app:boxCornerRadiusBottomEnd="5dp"
            app:boxCornerRadiusBottomStart="5dp"
            app:boxCornerRadiusTopEnd="5dp"
            app:boxCornerRadiusTopStart="5dp"
            app:boxStrokeColor="@color/bg_edittext_stroke"
            app:boxStrokeErrorColor="@color/style_color_input_border_error"
            app:boxStrokeWidth="1dp"
            app:boxStrokeWidthFocused="1dp"
            app:counterEnabled="true"
            app:counterMaxLength="500"
            app:hintTextColor="@color/bg_edittext_stroke">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editDescription"
                android:layout_width="match_parent"
                android:layout_height="90dp"
                android:fontFamily="@font/font_family_regular"
                android:gravity="top"
                android:inputType="textMultiLine"
                android:maxLength="500"
                android:maxLines="6"
                android:textColor="@color/style_color_text_primary"
                android:textSize="@dimen/normal_text_size"
                tools:ignore="SpUsage,TextSizeCheck,TextContrastCheck,
                VisualLintTextFieldSize" />

        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/btnCheckCrashLog"
            style="@style/Widget.Material3.CompoundButton.CheckBox"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginLeft="20dp"
            android:layout_marginRight="20dp"
            android:checked="true"
            android:fontFamily="@font/font_family_medium"
            android:text="@string/label_include_crash_log"
            android:textColor="@color/style_color_text_primary"
            android:textSize="@dimen/normal_text_size"
            app:buttonIconTint="@color/style_color_text_inverse"
            app:buttonTint="@color/style_color_button_primary"
            tools:ignore="SpUsage,TextSizeCheck,TouchTargetSizeCheck,
            VisualLintButtonSize" />

        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/btnCheckDeviceInfo"
            style="@style/Widget.Material3.CompoundButton.CheckBox"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginLeft="20dp"
            android:layout_marginRight="20dp"
            android:checked="true"
            android:fontFamily="@font/font_family_medium"
            android:text="@string/label_include_device_amp_app_information"
            android:textColor="@color/style_color_text_primary"
            android:textSize="@dimen/normal_text_size"
            app:buttonIconTint="@color/style_color_text_inverse"
            app:buttonTint="@color/style_color_button_primary"
            tools:ignore="SpUsage,TextSizeCheck,TouchTargetSizeCheck,
            VisualLintButtonSize" />

        <include
            android:id="@+id/crashInfo"
            layout="@layout/activity_app_crashed_1_p1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="20dp"
            android:layout_marginTop="10dp"
            android:layout_marginRight="20dp"
            android:layout_marginBottom="20dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSendReport"
            style="@style/Widget.Material3.Button.IconButton.Filled"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginLeft="20dp"
            android:layout_marginRight="20dp"
            android:fontFamily="@font/font_family_medium"
            android:text="@string/label_send_report"
            android:textAllCaps="false"
            android:textSize="@dimen/normal_text_size"
            app:backgroundTint="@color/style_color_button_primary"
            app:cornerRadius="5dp"
            app:icon="@drawable/ic_send_email"
            app:iconGravity="textStart"
            app:iconPadding="10dp"
            app:iconSize="24dp"
            tools:ignore="SpUsage,VisualLintButtonSize,TextSizeCheck" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnContinueAnyway"
            style="@style/Widget.Material3.Button.IconButton.Outlined"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginLeft="20dp"
            android:layout_marginRight="20dp"
            android:fontFamily="@font/font_family_medium"
            android:text="@string/label_continue_anyway"
            android:textColor="@color/style_color_button_outline"
            android:textSize="@dimen/normal_text_size"
            app:cornerRadius="5dp"
            app:icon="@drawable/ic_keyboard_arrow_right"
            app:iconGravity="textStart"
            app:iconPadding="10dp"
            app:iconSize="24dp"
            app:iconTint="@color/style_color_button_primary"
            app:strokeColor="@color/style_color_button_outline"
            app:strokeWidth="1dp"
            tools:ignore="SpUsage,VisualLintButtonSize,TextSizeCheck" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/btnTechnicalDetails"
            android:layout_width="wrap_content"
            android:layout_height="30dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_button_negative"
            android:clickable="true"
            android:drawableRight="@drawable/ic_arrow_down"
            android:drawablePadding="5dp"
            android:drawableTint="@color/style_color_button_primary"
            android:fontFamily="@font/font_family_medium"
            android:gravity="center"
            android:paddingLeft="10dp"
            android:paddingRight="5dp"
            android:text="@string/label_view_technical_details"
            android:textColor="@color/style_color_button_primary"
            android:textSize="@dimen/normal_text_size"
            tools:ignore="SpUsage,UseCompatTextViewDrawableXml,TextSizeCheck,TouchTargetSizeCheck" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/txtStacktrace"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="20dp"
            android:layout_marginTop="10dp"
            android:layout_marginRight="20dp"
            android:background="@drawable/bg_stacktrace"
            android:ellipsize="end"
            android:fontFamily="@font/font_family_regular"
            android:maxLength="800"
            android:padding="10dp"
            android:textColor="@color/style_color_text_secondary"
            android:textIsSelectable="true"
            android:textSize="@dimen/small_text_size"
            android:visibility="gone"
            tools:ignore="HardcodedText,SpUsage,TextSizeCheck"
            tools:text="java.lang.NullPointerException..." />

    </LinearLayout>
</ScrollView>