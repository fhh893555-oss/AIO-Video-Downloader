<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
  <item android:state_pressed="true">
    <shape android:shape="rectangle">
      <corners android:radius="@dimen/default_radius" />

      <gradient
        android:angle="45"
        android:centerColor="@color/color_primary"
        android:endColor="@color/color_secondary_variant"
        android:startColor="@color/color_primary_variant" />

      <stroke
        android:width="1dp"
        android:color="@color/color_secondary" />

      <padding
        android:bottom="10dp"
        android:left="14dp"
        android:right="14dp"
        android:top="10dp" />

    </shape>
  </item>

  <item>
    <shape android:shape="rectangle">
      <corners android:radius="@dimen/default_radius" />

      <gradient
        android:angle="45"
        android:centerColor="@color/gradient_middle"
        android:endColor="@color/gradient_end"
        android:startColor="@color/gradient_start" />

      <stroke
        android:width="1dp"
        android:color="@color/color_secondary_variant" />

      <solid android:color="@android:color/transparent" />

      <padding
        android:bottom="10dp"
        android:left="14dp"
        android:right="14dp"
        android:top="10dp" />

    </shape>
  </item>

</selector>