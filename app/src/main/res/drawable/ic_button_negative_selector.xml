<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

  <item android:state_pressed="true">
    <shape android:shape="rectangle">
      <corners android:radius="@dimen/cardview_default_radius" />

      <gradient
        android:angle="45"
        android:startColor="@color/color_primary_variant"
        android:centerColor="@color/color_primary"
        android:endColor="@color/color_secondary_variant" />

      <stroke
        android:width="1dp"
        android:color="#40FFFFFF" />

      <padding
        android:left="14dp"
        android:top="10dp"
        android:right="14dp"
        android:bottom="10dp" />

    </shape>

  </item>

  <!-- DEFAULT -->
  <item>

    <shape android:shape="rectangle">

      <corners android:radius="18dp" />

      <gradient
        android:angle="45"
        android:startColor="@color/gradient_start"
        android:centerColor="@color/gradient_middle"
        android:endColor="@color/gradient_end" />

      <stroke
        android:width="1dp"
        android:color="#55FFFFFF" />

      <solid android:color="@android:color/transparent" />

      <padding
        android:left="14dp"
        android:top="10dp"
        android:right="14dp"
        android:bottom="10dp" />

    </shape>

  </item>

</selector>