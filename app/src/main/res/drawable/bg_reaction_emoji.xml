<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
  <item
    android:state_selected="true">
    <shape android:shape="oval">
      <solid android:color="@color/style_color_primary" />
      <stroke
        android:width="2dp"
        android:color="@color/style_color_primary" />

      <size
        android:width="50dp"
        android:height="50dp" />
    </shape>
  </item>

  <item
    android:state_pressed="true">
    <shape android:shape="oval">
      <solid android:color="@color/style_color_primary_light" />

      <stroke
        android:width="2dp"
        android:color="@color/style_color_primary" />
      <size
        android:width="50dp"
        android:height="50dp" />
    </shape>
  </item>

  <item>
    <shape android:shape="oval">
      <solid android:color="@color/style_color_card" />

      <stroke
        android:width="1dp"
        android:color="@color/style_color_card_stroke" />

      <size
        android:width="50dp"
        android:height="50dp" />
    </shape>
  </item>

</selector>