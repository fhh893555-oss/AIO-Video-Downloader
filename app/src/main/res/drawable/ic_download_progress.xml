<?xml version="1.0" encoding="UTF-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

  <item android:id="@android:id/background">
    <shape>
      <corners android:radius="@dimen/default_radius" />
      <gradient
        android:angle="90"
        android:centerColor="@color/color_background"
        android:centerY="0.50"
        android:endColor="@color/color_card_stroke"
        android:startColor="@color/color_card_stroke" />
    </shape>
  </item>

  <item android:id="@android:id/secondaryProgress">
    <clip>
      <shape>
        <corners android:radius="@dimen/default_radius" />
        <gradient
          android:angle="90"
          android:endColor="@color/color_secondary"
          android:startColor="@color/color_primary" />
      </shape>
    </clip>
  </item>

  <item android:id="@android:id/progress">
    <clip>
      <shape>
        <corners android:radius="@dimen/default_radius" />
        <gradient
          android:angle="90"
          android:endColor="@color/color_secondary"
          android:startColor="@color/color_secondary_variant" />
      </shape>
    </clip>
  </item>
</layer-list>